{
  "name": "claude-usage-tracker",
  "version": "1.0.0",
  "description": "Compact desktop widget showing Claude Code utilization and Anthropic API spend",
  "main": "dist-main/main.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json && vite build",
    "start": "electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "author": "Dhyey Tandel",
  "license": "MIT",
  "dependencies": {
    "electron-log": "^5.1.0",
    "electron-store": "^8.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^31.0.1",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  },
  "build": {
    "appId": "com.dhyey.claude-usage-tracker",
    "productName": "Claude Usage Tracker",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-main/**/*",
      "dist-preload/**/*",
      "dist-renderer/**/*",
      "assets/**/*"
    ],
    "mac": {
      "target": {
        "target": "dmg",
        "arch": [
          "x64",
          "arm64"
        ]
      },
      "category": "public.app-category.utilities",
      "extendInfo": {
        "LSUIElement": true
      },
      "icon": "assets/icon.png"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
